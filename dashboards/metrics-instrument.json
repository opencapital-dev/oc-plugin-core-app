          "rawSql": "SELECT event_ts AS time, irr_annualized AS value FROM instrument_per_tick WHERE scope_id = '${portfolio_id}' AND instrument_id = '${instrument_id}' AND $__timeFilter(event_ts) ORDER BY event_ts ASC",
