{
  "title": "Analytics \u2014 Performance & Trade Stats",
  "uid": "metrics-analytics-numbat",
  "tags": [
    "portfolio",
    "analytics"
  ],
  "schemaVersion": 41,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "portfolio_id",
        "label": "Portfolio",
        "type": "query",
        "datasource": {
          "type": "core-datasource",
          "uid": "core-datasource"
        },
        "query": {
          "refId": "V",
          "source": "@bind(rows=\"portfolios{}\")\n@metric(output=\"table\")\ndef portfolios(rows):\n    return rows\n"
        },
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "options": [],
        "current": {}
      },
      {
        "name": "base_currency",
        "type": "textbox",
        "current": {
          "text": "GBP",
          "value": "GBP"
        },
        "query": "GBP",
        "label": "Base ccy"
      },
      {
        "name": "sample_interval",
        "type": "custom",
        "label": "Sample",
        "query": "1d,1h",
        "options": [
          {
            "text": "1d",
            "value": "1d",
            "selected": true
          },
          {
            "text": "1h",
            "value": "1h",
            "selected": false
          }
        ],
        "current": {
          "text": "1d",
          "value": "1d"
        }
      },
      {
        "name": "risk_free",
        "type": "textbox",
        "current": {
          "text": "0.04",
          "value": "0.04"
        },
        "query": "0.04",
        "label": "Risk-free (annualized)"
      },
      {
        "name": "benchmark_ids",
        "type": "textbox",
        "current": {
          "text": "",
          "value": ""
        },
        "query": "",
        "label": "Benchmark"
      },
      {
        "name": "benchmark_weights",
        "type": "textbox",
        "current": {
          "text": "null",
          "value": "null"
        },
        "query": "null",
        "label": "Benchmark weights (JSON list or null)"
      },
      {
        "name": "lookback_periods",
        "type": "textbox",
        "current": {
          "text": "60",
          "value": "60"
        },
        "query": "60",
        "label": "Beta rolling lookback (periods)"
      },
      {
        "name": "beta_mode",
        "type": "custom",
        "label": "Beta mode",
        "query": "rolling,expanding,both",
        "options": [
          {
            "text": "rolling",
            "value": "rolling",
            "selected": false
          },
          {
            "text": "expanding",
            "value": "expanding",
            "selected": false
          },
          {
            "text": "both",
            "value": "both",
            "selected": true
          }
        ],
        "current": {
          "text": "both",
          "value": "both"
        }
      }
    ]
  },
