{
  "type": "stat",
  "title": "Largest profit",
  "description": "Max single-closure PnL, base ccy.",
  "fieldConfig": {
    "defaults": {
      "unit": "locale",
      "decimals": 0,
      "color": {
        "mode": "fixed",
        "fixedColor": "green"
      }
    }
  },
  "options": {
    "colorMode": "value",
    "graphMode": "none",
    "reduceOptions": {
      "calcs": [
        "lastNotNull"
      ],
      "fields": "",
      "values": false
    },
    "text": {
      "titleSize": 16,
      "valueSize": 32
    },
    "textMode": "auto"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "source": "@bind(closures=\"closures{portfolio=\\\"$portfolio_id\\\"} @window\")\n@metric(output=\"scalar\")\ndef largest_profit(closures):\n    wins = closures.filter(pl.col(\"realized_pnl\") > 0)\n    return None if wins.is_empty() else float(wins[\"realized_pnl\"].max())\n"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
