{
  "type": "timeseries",
  "title": "R\u00b2 over time",
  "description": "Fraction of portfolio return variance explained by the benchmark, at each tick.",
  "fieldConfig": {
    "defaults": {
      "unit": "percentunit",
      "decimals": 2,
      "min": 0,
      "max": 1,
      "custom": {
        "drawStyle": "line",
        "lineWidth": 2,
        "fillOpacity": 10,
        "showPoints": "never",
        "spanNulls": false
      },
      "color": {
        "mode": "palette-classic"
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "ts"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "time"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "rolling"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Rolling R\u00b2"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "expanding"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Expanding R\u00b2"
          }
        ]
      }
    ]
  },
  "options": {
    "tooltip": {
      "mode": "multi",
      "sort": "none"
    },
    "legend": {
      "displayMode": "table",
      "placement": "bottom",
      "calcs": [
        "last",
        "mean"
      ]
    }
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/r_squared_series"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
