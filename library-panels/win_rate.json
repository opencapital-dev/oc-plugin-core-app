{
  "type": "stat",
  "title": "Win rate",
  "description": "n_wins / (n_wins + n_losses). Excludes breakeven (zero-PnL) closures.",
  "fieldConfig": {
    "defaults": {
      "unit": "percentunit",
      "decimals": 1,
      "min": 0,
      "max": 1,
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "red",
            "value": null
          },
          {
            "color": "yellow",
            "value": 0.5
          },
          {
            "color": "green",
            "value": 0.6
          }
        ]
      }
    }
  },
  "options": {
    "colorMode": "value",
    "graphMode": "none",
    "reduceOptions": {
      "calcs": [
        "lastNotNull"
      ],
      "fields": "",
      "values": false
    },
    "text": {
      "titleSize": 16,
      "valueSize": 32
    },
    "textMode": "auto"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/win_rate"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
