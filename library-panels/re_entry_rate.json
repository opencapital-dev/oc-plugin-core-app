{
  "type": "stat",
  "title": "Re-entry rate",
  "description": "n_re_entries / n_instruments_traded. Higher = more re-entered names.",
  "fieldConfig": {
    "defaults": {
      "unit": "percentunit",
      "decimals": 2,
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "blue",
            "value": null
          }
        ]
      }
    },
    "overrides": []
  },
  "options": {
    "colorMode": "value",
    "graphMode": "none",
    "reduceOptions": {
      "calcs": [
        "lastNotNull"
      ],
      "fields": "",
      "values": false
    },
    "text": {
      "titleSize": 16,
      "valueSize": 32
    },
    "textMode": "auto"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "source": "@bind(cycles=\"cycles{portfolio=\\\"$portfolio_id\\\"} @window\")\n@metric(output=\"scalar\")\ndef re_entry_rate(cycles):\n    n = cycles.height\n    if n == 0:\n        return float(\"nan\")\n    re_entries = cycles.filter(pl.col(\"was_re_entry\") > 0).height\n    return re_entries / n\n"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
