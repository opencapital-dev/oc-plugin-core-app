{
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  },
  "description": "Quantity (step line, left axis) and last price (smooth, right axis). Quantity changes only on trades; price ticks on every mark.",
  "fieldConfig": {
    "defaults": {
      "decimals": 4,
      "unit": "short",
      "color": {
        "mode": "palette-classic"
      },
      "custom": {
        "drawStyle": "line",
        "lineInterpolation": "smooth",
        "lineWidth": 2,
        "fillOpacity": 0,
        "gradientMode": "none",
        "pointSize": 0,
        "showPoints": "never",
        "spanNulls": true,
        "axisPlacement": "auto",
        "scaleDistribution": {
          "type": "linear"
        }
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "Quantity"
        },
        "properties": [
          {
            "id": "custom.lineInterpolation",
            "value": "stepAfter"
          },
          {
            "id": "custom.axisPlacement",
            "value": "left"
          },
          {
            "id": "custom.axisLabel",
            "value": "Quantity"
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#3D85C6"
            }
          },
          {
            "id": "custom.fillOpacity",
            "value": 15
          },
          {
            "id": "custom.gradientMode",
            "value": "opacity"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Last price"
        },
        "properties": [
          {
            "id": "custom.axisPlacement",
            "value": "right"
          },
          {
            "id": "custom.axisLabel",
            "value": "Price"
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#E69138"
            }
          }
        ]
      }
    ]
  },
  "options": {
    "legend": {
      "calcs": [
        "lastNotNull",
        "min",
        "max"
      ],
      "displayMode": "table",
      "placement": "right",
      "showLegend": true
    },
    "tooltip": {
      "mode": "multi",
      "sort": "desc"
    }
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/instrument_quantity_price"
    }
  ],
  "title": "Quantity & price",
  "type": "timeseries",
  "transformations": [
    {
      "id": "organize",
      "options": {
        "excludeByName": {
          "portfolio_id": true,
          "instrument_id": true,
          "direction": true,
          "currency": true,
          "avg_cost_avg_native": true,
          "avg_cost_avg_base": true,
          "realized_equity_avg_native": true,
          "realized_equity_avg_base": true,
          "realized_forex_avg_base": true,
          "unrealized_equity_avg_native": true,
          "unrealized_equity_avg_base": true,
          "unrealized_forex_avg_base": true,
          "lot_count": true,
          "position_size_base": true
        },
        "renameByName": {
          "quantity": "Quantity",
          "last_price": "Last price"
        },
        "indexByName": {}
      }
    }
  ]
}
