{
  "description": "Time-weighted return over the window. Flow-neutralised against deposits, withdrawals, and in-kind transfers.",
  "fieldConfig": {
    "defaults": {
      "decimals": 2,
      "unit": "percentunit",
      "color": {
        "mode": "thresholds"
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "red",
            "value": null
          },
          {
