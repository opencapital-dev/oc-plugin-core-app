          },
          {
            "color": "yellow",
            "value": 0.0001
          },
          {
            "color": "green",
            "value": 0.05
          }
        ]
      }
    },
    "overrides": []
  },
  "options": {
    "colorMode": "value",
    "graphMode": "none",
    "justifyMode": "auto",
    "orientation": "auto",
    "reduceOptions": {
      "calcs": [
        "lastNotNull"
      ],
      "fields": "",
      "values": false
    },
    "text": {
      "titleSize": 18,
      "valueSize": 32
    },
    "textMode": "auto"
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/total_return"
    }
  ],
  "title": "Total Return (TWR)",
  "type": "stat",
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
