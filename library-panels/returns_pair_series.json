{
  "type": "timeseries",
  "title": "Per-period returns: portfolio vs benchmark",
  "description": "The raw (r_p, r_b) pairs that feed the regression. Useful sanity check that the chosen benchmark co-moves with the portfolio.",
  "fieldConfig": {
    "defaults": {
      "unit": "percentunit",
      "decimals": 3,
      "custom": {
        "drawStyle": "line",
        "lineWidth": 1,
        "fillOpacity": 0,
        "showPoints": "auto",
        "pointSize": 4,
        "spanNulls": false
      },
      "color": {
        "mode": "palette-classic"
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "ts"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "time"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "r_p"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Portfolio return (per period)"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "r_b"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Benchmark return (per period)"
          }
        ]
      }
    ]
  },
  "options": {
    "tooltip": {
      "mode": "multi",
      "sort": "none"
    },
    "legend": {
      "displayMode": "table",
      "placement": "bottom",
      "calcs": [
        "last",
        "mean",
        "stdDev"
      ]
    }
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/returns_pair_series"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
