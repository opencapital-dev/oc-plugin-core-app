{
  "type": "table",
  "title": "Drawdown episodes",
  "description": "Each peak \u2192 trough \u2192 (optional) recovery cycle on the cumulative-return curve.",
  "fieldConfig": {
    "defaults": {
      "custom": {
        "align": "auto",
        "displayMode": "auto"
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "depth"
        },
        "properties": [
          {
            "id": "unit",
            "value": "percentunit"
          },
          {
            "id": "decimals",
            "value": 2
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "time_to_trough_sec"
        },
        "properties": [
          {
            "id": "unit",
            "value": "s"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "time_to_recover_sec"
        },
        "properties": [
          {
            "id": "unit",
            "value": "s"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "peak_ts"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Peak"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "trough_ts"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Trough"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "recovery_ts"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Recovered"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "depth"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Depth"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "time_to_trough_sec"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Time to trough"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "time_to_recover_sec"
        },
        "properties": [
          {
            "id": "displayName",
            "value": "Time to recover"
          }
        ]
      }
    ]
  },
  "options": {
    "showHeader": true,
    "footer": {
      "show": false
    }
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/drawdown_episodes"
    }
  ],
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  }
}
