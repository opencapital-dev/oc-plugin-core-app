{
  "datasource": {
    "type": "core-datasource",
    "uid": "core-datasource"
  },
  "description": "Latest snapshot per cash bucket. Currency badge, gauge bars on values, sign-coloured PnL cells. Total gross / Total net are highlighted on the right.",
  "fieldConfig": {
    "defaults": {
      "decimals": 2,
      "custom": {
        "align": "right",
        "cellOptions": {
          "type": "auto"
        },
        "filterable": true,
        "inspect": false
      },
      "thresholds": {
        "mode": "absolute",
        "steps": [
          {
            "color": "transparent",
            "value": null
          }
        ]
      }
    },
    "overrides": [
      {
        "matcher": {
          "id": "byName",
          "options": "Currency"
        },
        "properties": [
          {
            "id": "custom.align",
            "value": "center"
          },
          {
            "id": "custom.width",
            "value": 90
          },
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background",
              "mode": "basic"
            }
          },
          {
            "id": "mappings",
            "value": [
              {
                "type": "value",
                "options": {
                  "GBP": {
                    "text": "\u00a3 GBP",
                    "color": "blue",
                    "index": 0
                  },
                  "USD": {
                    "text": "$ USD",
                    "color": "green",
                    "index": 1
                  },
                  "EUR": {
                    "text": "\u20ac EUR",
                    "color": "purple",
                    "index": 2
                  },
                  "CAD": {
                    "text": "C$ CAD",
                    "color": "orange",
                    "index": 3
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Balance (native)"
        },
        "properties": [
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "gauge",
              "mode": "gradient"
            }
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#3D85C6"
            }
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Cash value (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "gauge",
              "mode": "gradient"
            }
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#3D85C6"
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Equity value (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "gauge",
              "mode": "gradient"
            }
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "#E69138"
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Total value (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "gauge",
              "mode": "lcd"
            }
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "white"
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byRegexp",
          "options": "^(Realized|Unrealized|Fees).*"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          {
            "id": "thresholds",
            "value": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "dark-red",
                  "value": null
                },
                {
                  "color": "transparent",
                  "value": -0.0001
                },
                {
                  "color": "transparent",
                  "value": 0
                },
                {
                  "color": "transparent",
                  "value": 0.0001
                },
                {
                  "color": "dark-green",
                  "value": 1
                }
              ]
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Fees (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          {
            "id": "thresholds",
            "value": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "transparent",
                  "value": null
                },
                {
                  "color": "dark-red",
                  "value": 0.0001
                }
              ]
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Total gross (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          {
            "id": "thresholds",
            "value": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "dark-red",
                  "value": null
                },
                {
                  "color": "transparent",
                  "value": -0.0001
                },
                {
                  "color": "transparent",
                  "value": 0.0001
                },
                {
                  "color": "dark-green",
                  "value": 1
                }
              ]
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byName",
          "options": "Total net (base)"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-background",
              "mode": "gradient"
            }
          },
          {
            "id": "thresholds",
            "value": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "dark-red",
                  "value": null
                },
                {
                  "color": "transparent",
                  "value": -0.0001
                },
                {
                  "color": "transparent",
                  "value": 0.0001
                },
                {
                  "color": "dark-green",
                  "value": 1
                }
              ]
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      },
      {
        "matcher": {
          "id": "byRegexp",
          "options": "^(Deposits|Withdrawals).*"
        },
        "properties": [
          {
            "id": "custom.cellOptions",
            "value": {
              "type": "color-text"
            }
          },
          {
            "id": "color",
            "value": {
              "mode": "fixed",
              "fixedColor": "text-secondary"
            }
          },
          {
            "id": "decimals",
            "value": 0
          },
          {
            "id": "unit",
            "value": "locale"
          }
        ]
      }
    ]
  },
  "options": {
    "showHeader": true,
    "cellHeight": "md",
    "footer": {
      "show": true,
      "reducer": [
        "sum"
      ],
      "fields": [
        "Cash value (base)",
        "Equity value (base)",
        "Total value (base)",
        "Realized equity (base)",
        "Realized forex (base)",
        "Realized interest (base)",
        "Realized dividends (base)",
        "Fees (base)",
        "Total gross (base)",
        "Total net (base)"
      ]
    },
    "sortBy": [
      {
        "displayName": "Total value (base)",
        "desc": true
      }
    ]
  },
  "targets": [
    {
      "refId": "A",
      "datasource": {
        "type": "core-datasource",
        "uid": "core-datasource"
      },
      "ref": "core-app/portfolio_cash_positions"
    }
  ],
  "title": "Cash positions \u2014 latest per currency",
  "type": "table",
  "transformations": [
    {
      "id": "organize",
      "options": {
        "excludeByName": {
          "portfolio_id": true,
          "ts": true,
          "base_currency": true
        },
        "renameByName": {
          "currency": "Currency",
          "balance_native": "Balance (native)",
          "cash_value_base": "Cash value (base)",
          "realized_interest_base": "Realized interest (base)",
          "realized_dividends_base": "Realized dividends (base)",
          "realized_fx_avg_base": "Realized FX (base)",
          "unrealized_fx_avg_base": "Unrealized FX (base)",
          "fees_base": "Fees (base)",
          "deposits_cumulative_native": "Deposits (native)",
          "withdrawals_cumulative_native": "Withdrawals (native)"
        },
        "indexByName": {}
      }
    }
  ]
}
